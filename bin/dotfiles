#!/usr/bin/env bash
set -e

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
RESET='\033[0m'

# Auto-detect dotfiles directory (script lives at ~/dotfiles/bin/dotfiles)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

has_remote() {
    git -C "$DOTFILES_DIR" remote | grep -q .
}

# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

cmd_sync() {
    echo -e "${BLUE}Pulling latest changes...${RESET}"
    git -C "$DOTFILES_DIR" pull --rebase

    echo -e "${BLUE}Re-running install script...${RESET}"
    "$DOTFILES_DIR/install.sh"

    echo -e "${GREEN}Sync complete.${RESET}"
}

cmd_push() {
    git -C "$DOTFILES_DIR" add -A

    echo -e "${BLUE}Staged changes:${RESET}"
    git -C "$DOTFILES_DIR" diff --cached --stat

    if ! git -C "$DOTFILES_DIR" diff --cached --quiet; then
        printf "%b" "${YELLOW}Commit message (empty = 'Update dotfiles'): ${RESET}"
        read -r msg
        if [[ -z "$msg" ]]; then
            msg="Update dotfiles"
        fi

        git -C "$DOTFILES_DIR" commit -m "$msg"
    else
        echo -e "${YELLOW}Nothing staged to commit.${RESET}"
    fi

    if has_remote; then
        echo -e "${BLUE}Pushing to remote...${RESET}"
        git -C "$DOTFILES_DIR" push
        echo -e "${GREEN}Push complete.${RESET}"
    else
        echo -e "${YELLOW}No remote configured — skipping push.${RESET}"
    fi
}

cmd_status() {
    echo -e "${BLUE}Local changes:${RESET}"
    git -C "$DOTFILES_DIR" status --short

    if has_remote; then
        local branch
        branch="$(git -C "$DOTFILES_DIR" rev-parse --abbrev-ref HEAD)"
        local remote_ref
        remote_ref="$(git -C "$DOTFILES_DIR" for-each-ref --format='%(upstream:short)' "refs/heads/${branch}" 2>/dev/null)"

        if [[ -n "$remote_ref" ]]; then
            git -C "$DOTFILES_DIR" fetch --quiet 2>/dev/null || true
            local ahead behind
            ahead="$(git -C "$DOTFILES_DIR" rev-list --count "${remote_ref}..HEAD" 2>/dev/null || echo 0)"
            behind="$(git -C "$DOTFILES_DIR" rev-list --count "HEAD..${remote_ref}" 2>/dev/null || echo 0)"
            echo ""
            echo -e "${BLUE}Remote comparison (${remote_ref}):${RESET}"
            echo -e "  Ahead:  ${GREEN}${ahead}${RESET} commit(s)"
            echo -e "  Behind: ${YELLOW}${behind}${RESET} commit(s)"
        else
            echo ""
            echo -e "${YELLOW}Branch '${branch}' has no upstream tracking branch.${RESET}"
        fi
    else
        echo ""
        echo -e "${YELLOW}No remote configured — showing local status only.${RESET}"
    fi
}

cmd_edit() {
    local editor="${EDITOR:-}"
    if [[ -z "$editor" ]]; then
        if command -v vim &>/dev/null; then
            editor="vim"
        else
            editor="vi"
        fi
    fi
    cd "$DOTFILES_DIR" && exec "$editor" .
}

cmd_help() {
    echo -e "${BLUE}dotfiles${RESET} — manage your dotfiles"
    echo ""
    echo "Usage: dotfiles <command>"
    echo ""
    echo "Commands:"
    echo -e "  ${GREEN}sync${RESET}    Pull latest changes and re-run install.sh"
    echo -e "  ${GREEN}push${RESET}    Stage all changes, commit, and push to remote"
    echo -e "  ${GREEN}status${RESET}  Show local changes and ahead/behind remote count"
    echo -e "  ${GREEN}edit${RESET}    Open dotfiles directory in \$EDITOR"
    echo -e "  ${GREEN}help${RESET}    Show this help message"
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

case "${1:-help}" in
    sync)   cmd_sync ;;
    push)   cmd_push ;;
    status) cmd_status ;;
    edit)   cmd_edit ;;
    help|--help|-h) cmd_help ;;
    *)
        echo -e "${YELLOW}Unknown command: ${1}${RESET}"
        echo ""
        cmd_help
        exit 1
        ;;
esac
